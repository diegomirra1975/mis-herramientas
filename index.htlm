// Fill default difusion text for items without one
DATA.forEach(d=>{
  if(!d.texto){
    d.texto = `Hoy conmemoramos: ${d.title}. Desde el SAPS del Hospital Narciso López acompañamos esta fecha con información y actividades para la comunidad. Consultá en tu centro de salud más cercano.`;
  }
});

let currentCat = "todas";
let currentMonth = null; // null = todas
let currentSearch = "";

const monthNav = document.getElementById('monthNav');
const todosBtn = document.createElement('button');
todosBtn.className='mbtn'; todosBtn.textContent='Todo el año'; todosBtn.setAttribute('aria-pressed','true');
todosBtn.onclick=()=>{currentMonth=null; render();};
monthNav.appendChild(todosBtn);
MESES.forEach((m,i)=>{
  const b=document.createElement('button');
  b.className='mbtn'; b.textContent=m; b.setAttribute('aria-pressed','false');
  b.onclick=()=>{currentMonth=i+1; render();};
  monthNav.appendChild(b);
});

function updateMonthButtons(){
  const btns = monthNav.querySelectorAll('.mbtn');
  btns.forEach((b,i)=>{
    if(i===0) b.setAttribute('aria-pressed', currentMonth===null ? 'true':'false');
    else b.setAttribute('aria-pressed', currentMonth===i ? 'true':'false');
  });
}

document.querySelectorAll('.catbtn').forEach(b=>{
  b.onclick=()=>{
    currentCat = b.dataset.cat;
    document.querySelectorAll('.catbtn').forEach(x=>x.setAttribute('aria-pressed', x===b ? 'true':'false'));
    render();
  };
});

document.getElementById('search').addEventListener('input', (e)=>{
  currentSearch = e.target.value.trim().toLowerCase();
  render();
});

function matchesFilters(d){
  if(currentCat!=='todas' && d.cat!==currentCat) return false;
  if(currentMonth!==null && d.month!==currentMonth) return false;
  if(currentSearch){
    const hay = (d.title+' '+d.desc).toLowerCase();
    if(!hay.includes(currentSearch)) return false;
  }
  return true;
}

function render(){
  updateMonthButtons();
  const container = document.getElementById('results');
  container.innerHTML='';
  const filtered = DATA.filter(matchesFilters);
  if(filtered.length===0){
    container.innerHTML = '<div class="empty">No se encontraron efemérides con estos filtros.</div>';
    return;
  }
  for(let m=1;m<=12;m++){
    const items = filtered.filter(d=>d.month===m).sort((a,b)=>a.sortDay-b.sortDay);
    if(items.length===0) continue;
    const group = document.createElement('div');
    group.className='month-group';
    group.innerHTML = `<div class="month-title">${MESES[m-1]}</div>`;
    const cards = document.createElement('div');
    cards.className='cards';
    items.forEach(d=>{
      const card = document.createElement('div');
      card.className='card';
      const dayLabel = typeof d.day==='number' ? d.day : '•';
      card.innerHTML = `
        <div class="daybadge ${d.cat}">${dayLabel}</div>
        <div class="card-body">
          <span class="card-title">${d.title}</span><span class="tag ${d.cat}">${d.cat==='patria'?'Patria':'Salud'}</span>
          <div class="card-meta">${typeof d.day==='number' ? d.day+' de '+MESES[m-1] : d.day+', '+MESES[m-1]}</div>
        </div>`;
      card.onclick=()=>openModal(d);
      cards.appendChild(card);
    });
    group.appendChild(cards);
    container.appendChild(group);
  }
}

// ---- Upcoming widget ----
const TODAY = new Date(2026,6,3); // 3 de julio de 2026
function daysUntil(d){
  const thisYearDate = new Date(2026, d.month-1, typeof d.day==='number'?d.day:15);
  let diff = Math.ceil((thisYearDate - TODAY)/86400000);
  if(diff < -1){ // ya pasó este año, proyectar al año siguiente para orden, pero no mostramos
    diff += 365;
  }
  return diff;
}
function renderUpcoming(){
  const row = document.getElementById('upcomingRow');
  const upcoming = DATA
    .map(d=>({d, diff: daysUntil(d)}))
    .filter(x=>x.diff>=0)
    .sort((a,b)=>a.diff-b.diff)
    .slice(0,8);
  row.innerHTML='';
  upcoming.forEach(({d,diff})=>{
    const c = document.createElement('div');
    c.className='upc-card';
    const dayLabel = typeof d.day==='number' ? `${d.day} ${MESES[d.month-1].slice(0,3)}` : `${MESES[d.month-1].slice(0,3)}`;
    c.innerHTML = `<div class="upc-date">${dayLabel} · ${diff===0?'HOY':diff+' días'}</div><div class="upc-title">${d.title}</div>`;
    c.onclick=()=>openModal(d);
    row.appendChild(c);
  });
}

// ---- Modal ----
const overlay = document.getElementById('overlay');
let currentItem = null;

function openModal(d){
  currentItem = d;
  document.getElementById('modalTag').textContent = d.cat==='patria' ? 'Fecha patria' : 'Día de salud';
  document.getElementById('modalTag').className = 'tag '+d.cat;
  document.getElementById('modalTitle').textContent = d.title;
  document.getElementById('modalFecha').textContent = (typeof d.day==='number' ? d.day+' de '+MESES[d.month-1] : d.day+' de '+MESES[d.month-1]);
  document.getElementById('modalDesc').textContent = d.desc;
  document.getElementById('modalFuente').textContent = 'Fuente: '+d.fuente;

  const linksEl = document.getElementById('modalLinks');
  linksEl.innerHTML = '';
  const q = encodeURIComponent(d.title);
  const linksToShow = [];
  if(d.cat==='patria'){
    linksToShow.push({label:'Calendario oficial de feriados (Nación)', url:'https://www.argentina.gob.ar/jefatura/feriados-nacionales-2026'});
  } else {
    linksToShow.push({label:'Buscar en Ministerio de Salud (Nación)', url:`https://www.google.com/search?q=${q}+site:argentina.gob.ar`});
    linksToShow.push({label:'Buscar en Ministerio de Salud (PBA)', url:`https://www.google.com/search?q=${q}+site:gba.gob.ar`});
    linksToShow.push({label:'Buscar en OPS/OMS', url:`https://www.google.com/search?q=${q}+site:paho.org+OR+site:who.int`});
  }
  linksToShow.forEach(l=>{
    const a = document.createElement('a');
    a.href = l.url; a.target='_blank'; a.rel='noopener';
    a.className = 'btn ghost';
    a.style.textDecoration='none'; a.style.display='inline-block';
    a.textContent = l.label;
    linksEl.appendChild(a);
  });
  const actsEl = document.getElementById('modalActs');
  actsEl.innerHTML='';
  if(d.acts && d.acts.length){
    d.acts.forEach(a=>{
      const li=document.createElement('li'); li.textContent=a; actsEl.appendChild(li);
    });
  } else {
    actsEl.innerHTML = '<li>Sin sugerencias cargadas todavía — se puede completar según necesidad del equipo.</li>';
  }
  document.getElementById('modalTexto').value = d.texto;
  document.getElementById('savedFlag').style.display='none';
  loadNote(d.id);
  overlay.classList.add('open');
}
document.getElementById('closeModal').onclick=()=>overlay.classList.remove('open');
overlay.addEventListener('click',(e)=>{ if(e.target===overlay) overlay.classList.remove('open'); });

document.getElementById('copyBtn').onclick=()=>{
  const ta = document.getElementById('modalTexto');
  ta.select(); ta.setSelectionRange(0,99999);
  navigator.clipboard.writeText(ta.value).then(()=>{
    const btn = document.getElementById('copyBtn');
    const original = btn.textContent;
    btn.textContent='Copiado ✓';
    setTimeout(()=>btn.textContent=original,1500);
  }).catch(()=>{ document.execCommand('copy'); });
};
document.getElementById('resetBtn').onclick=()=>{
  if(currentItem) document.getElementById('modalTexto').value = currentItem.texto;
};

// ---- Personal notes via window.storage ----
async function loadNote(id){
  const noteEl = document.getElementById('modalNote');
  noteEl.value='';
  try{
    const res = await window.storage.get('nota:'+id, false);
    if(res && res.value) noteEl.value = res.value;
  }catch(e){ /* no note saved yet */ }
}
document.getElementById('saveNoteBtn').onclick=async ()=>{
  if(!currentItem) return;
  const val = document.getElementById('modalNote').value;
  try{
    await window.storage.set('nota:'+currentItem.id, val, false);
    const flag = document.getElementById('savedFlag');
    flag.style.display='inline';
    setTimeout(()=>flag.style.display='none',1800);
  }catch(e){
    alert('No se pudo guardar la nota en este momento.');
  }
};

render();
renderUpcoming();
</script>
</body>
</html>
